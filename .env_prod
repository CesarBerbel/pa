STATIC_URL=/static/
STATIC_ROOT=staticfiles

MEDIA_URL=/media/
MEDIA_ROOT=media


# =============================================================================
# Security - production
# =============================================================================

SECURE_SSL_REDIRECT=True

# Ativar apenas se estiver atrás de proxy confiável, como Nginx, Render,
# Railway, Fly.io, Heroku ou outro proxy que envie X-Forwarded-Proto=https.
SECURE_PROXY_SSL_HEADER=True
USE_X_FORWARDED_HOST=True

SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

CSRF_COOKIE_HTTPONLY=False

SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax

SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True

# Só use True quando tiver certeza de que todos os subdomínios usam HTTPS.
SECURE_HSTS_PRELOAD=False

SECURE_REFERRER_POLICY=same-origin
X_FRAME_OPTIONS=DENY


# =============================================================================
# Email - SMTP example
